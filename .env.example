# Portfolio Tracker — Environment Configuration
# Copy to .env and fill in values. NEVER commit .env.

# --- Shared TimescaleDB (same instance as claude-trader) ---
PT_DB_HOST=localhost
PT_DB_PORT=5434
PT_DB_NAME=claude_trader
PT_DB_USER=trader
PT_DB_PASSWORD=trader_dev_2024
PT_DB_SCHEMA=portfolio

# --- API Keys (free-tier defaults; upgrade as needed) ---
# Twelve Data: https://twelvedata.com — 800 calls/day free
TWELVE_DATA_API_KEY=

# Finnhub: https://finnhub.io — 60 calls/min free
FINNHUB_API_KEY=

# Marketaux: https://www.marketaux.com — 100 calls/day free
MARKETAUX_API_KEY=

# EOD Historical Data (optional, paid €19.99/mo for global stocks)
EODHD_API_KEY=

# CoinGecko: NO key needed for free tier (10 req/s)
# Frankfurter (ECB FX): NO key needed, no limits

# --- LLM Insights (reuse claude-trader OpenRouter key or set own) ---
OPENROUTER_API_KEY=

# --- Server ports ---
PT_API_PORT=8430
PT_FRONTEND_PORT=5174

# --- Defaults ---
PT_BASE_CURRENCY=EUR
