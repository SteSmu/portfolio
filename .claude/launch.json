{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend-dev",
      "runtimeExecutable": "./node_modules/.bin/vite",
      "runtimeArgs": ["--host", "127.0.0.1", "--port", "5175"],
      "cwd": "frontend",
      "port": 5175,
      "autoPort": true
    },
    {
      "name": "backend-dev",
      "runtimeExecutable": ".venv/bin/uvicorn",
      "runtimeArgs": ["pt.api.app:app", "--reload", "--port", "8430"],
      "port": 8430,
      "env": { "PT_DB_PORT": "5434" }
    }
  ]
}
